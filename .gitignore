# Under work_files, only keep actual content files tracked.
# This applies recursively, so new folders will also ignore LaTeX build junk.
work_files/**
!work_files/**/
!work_files/**/*.md
!work_files/**/*.tex
!work_files/**/*.pdf

# Ignore LaTeX build artifacts across the repo.
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc

# Ignore Lean build artifacts.
**/.lake/
